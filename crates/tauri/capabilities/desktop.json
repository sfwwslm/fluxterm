{
  "identifier": "desktop-capability",
  "platforms": ["macOS", "windows", "linux"],
  "windows": ["main"],
  "permissions": [
    "dialog:default",
    "window-state:default",
    {
      "identifier": "opener:default",
      "allow": [
        {
          "app": "firefox",
          "url": "http://*"
        },
        {
          "app": "firefox",
          "url": "https://*"
        },
        {
          "app": "msedge",
          "url": "http://*"
        },
        {
          "app": "msedge",
          "url": "https://*"
        },
        {
          "app": "chrome",
          "url": "http://*"
        },
        {
          "app": "chrome",
          "url": "https://*"
        }
      ]
    }
  ]
}
