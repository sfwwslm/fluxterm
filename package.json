{
  "name": "fluxterm",
  "private": true,
  "version": "0.1.0-beta.11",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tauri build",
    "build:fast": "tauri build -- --profile fast-release",
    "web:dev": "vite",
    "web:build": "vite build",
    "tauri": "tauri",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx --max-warnings=0",
    "preview": "vite preview",
    "prune": "ts-prune",
    "format": "prettier --write src/",
    "format:all": "pnpm format && cargo fmt",
    "check": "pnpm type-check && pnpm lint",
    "check:all": "pnpm type-check && pnpm lint && cargo clippy --all-targets --all-features -- -D warnings",
    "code:stats": "node --experimental-strip-types scripts/count-code-lines.ts"
  },
  "dependencies": {
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "~2.3.2",
    "@tauri-apps/plugin-dialog": "2.6.0",
    "@tauri-apps/plugin-fs": "2.4.5",
    "@tauri-apps/plugin-log": "2.8.0",
    "@tauri-apps/plugin-opener": "2.5.3",
    "@tauri-apps/plugin-updater": "~2.10.0",
    "@tauri-apps/plugin-window-state": "2.4.1",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-search": "0.16.0",
    "@xterm/addon-unicode11": "0.9.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "5.5.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.10.0",
    "@types/node": "25.0.7",
    "@types/react": "19.2.8",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.2",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "3.7.4",
    "ts-prune": "0.10.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "7.3.1"
  },
  "packageManager": "pnpm@10.28.0"
}
