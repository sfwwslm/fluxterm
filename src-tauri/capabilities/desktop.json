{
  "identifier": "desktop-capability",
  "platforms": ["macOS", "windows", "linux"],
  "windows": ["main", "widget-*", "subapp-*"],
  "permissions": [
    "updater:default",
    "dialog:default",
    "window-state:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$HOME"
        },
        {
          "path": "$HOME/.vust"
        },
        {
          "path": "$HOME/.vust/**"
        },
        {
          "path": "$HOME/**"
        }
      ]
    },
    {
      "identifier": "opener:default",
      "allow": [
        {
          "app": "firefox",
          "url": "http://*"
        },
        {
          "app": "firefox",
          "url": "https://*"
        },
        {
          "app": "msedge",
          "url": "http://*"
        },
        {
          "app": "msedge",
          "url": "https://*"
        },
        {
          "app": "chrome",
          "url": "http://*"
        },
        {
          "app": "chrome",
          "url": "https://*"
        }
      ]
    }
  ]
}
